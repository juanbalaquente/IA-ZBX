# Exemplo de arquivo de variaveis de ambiente.
# Nao comite suas chaves reais no repositorio.

VITE_API_BASE_URL=https://api.seusistema.local/zabbix/api_jsonrpc.php
VITE_API_TOKEN=coloque_seu_token_aqui
# Ou, se preferir, use login de usuario:
# VITE_ZABBIX_USER=seu_usuario
# VITE_ZABBIX_PASSWORD=sua_senha

AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=IA-ZBX

NIGHTOPS_DEFAULT_START_HOUR=19
NIGHTOPS_DEFAULT_END_HOUR=7
NIGHTOPS_TIMEZONE=America/Sao_Paulo
NIGHTOPS_MIN_DURATION_MINUTES=5
NIGHTOPS_CORRELATION_WINDOW_MINUTES=10
